rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // =============================================
    // HELPER FUNCTIONS
    // =============================================

    // Is the request from a logged-in user?
    function isAuthenticated() {
      return request.auth != null;
    }

    // Is the requester the master admin?
    function isMasterAdmin() {
      return isAuthenticated() &&
             request.auth.token.email == 'elsoncontador.st@gmail.com';
    }

    // Is the requester the owner of a given userId?
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Is the requester a member of the clinic (has managerId matching the owner)?
    function isClinicMember(managerId) {
      return isAuthenticated() && (
        request.auth.uid == managerId ||
        get(/databases/$(database)/documents/user_profiles/$(request.auth.uid)).data.managerId == managerId
      );
    }

    // Is the requester a verified member of the patient's multidisciplinar team?
    // Requires predictable ID: patientId_professionalId
    function isTeamMember(patientId) {
      return isAuthenticated() && 
             exists(/databases/$(database)/documents/patient_teams/$(patientId + "_" + request.auth.uid));
    }

    // =============================================
    // MASTER ADMIN (Full access for system owner)
    // =============================================
    match /{document=**} {
      allow read, write: if isMasterAdmin();
    }

    // =============================================
    // USER PROFILES
    // =============================================
    // Public read needed for booking (to get clinic name/manager)
    match /user_profiles/{userId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update, delete: if isOwner(userId) || isMasterAdmin();
    }

    // =============================================
    // SYSTEM USERS (Authenticated only)
    // =============================================
    match /system_users/{userId} {
      allow read, write: if isAuthenticated();
    }

    // =============================================
    // PATIENTS (Sensitive PHI - Clinic-scoped)
    // =============================================
    match /patients/{patientId} {
      allow read, write: if isAuthenticated() && (
        // Owner of the clinic (Manager)
        request.auth.uid == data.managerId ||
        // Professional who created the record
        request.auth.uid == data.professionalId ||
        // Legacy/fallback manager check
        request.auth.uid == resource.data.managerId ||
        request.auth.uid == resource.data.professionalId ||
        // Members of the same clinic
        get(/databases/$(database)/documents/user_profiles/$(request.auth.uid)).data.managerId == resource.data.managerId ||
        // Verified Team Members (multidisciplinary)
        isTeamMember(patientId)
      );
      allow create: if isAuthenticated();
    }

    // Mixed anamnesis (subcollection under patients)
    match /patients/{patientId}/mixed_anamnesis/{docId} {
      allow read, write: if isAuthenticated() && (
        isTeamMember(patientId) || 
        request.auth.uid == get(/databases/$(database)/documents/patients/$(patientId)).data.professionalId ||
        get(/databases/$(database)/documents/user_profiles/$(request.auth.uid)).data.managerId == 
        get(/databases/$(database)/documents/patients/$(patientId)).data.managerId
      );
    }

    // =============================================
    // CLINICAL DATA (EMR - PHI, auth required)
    // =============================================
    match /clinical_notes/{noteId} {
      allow read, write: if isAuthenticated();
    }

    match /prescriptions/{prescriptionId} {
      allow read, write: if isAuthenticated();
    }

    match /exam_requests/{requestId} {
      allow read, write: if isAuthenticated();
    }

    match /patient_evolutions/{evolutionId} {
      allow read, write: if isAuthenticated();
    }

    match /anamneses/{anamnesisId} {
      allow read, write: if isAuthenticated();
    }

    // =============================================
    // TEAM MANAGEMENT
    // =============================================
    match /patient_teams/{teamId} {
      allow read, write: if isAuthenticated();
    }

    match /team_invitations/{invitationId} {
      allow read, write: if isAuthenticated();
    }

    // =============================================
    // USER DATA (Core user document and subcollections)
    // =============================================
    match /users/{userId} {
      allow read, write: if isOwner(userId) || isMasterAdmin();
      
      // Subcollections under users/{userId}
      match /appointments/{appointmentId} {
        allow read: if isAuthenticated();
        allow create: if request.auth != null || request.resource.data.bookedOnline == true;
        allow update, delete: if isAuthenticated();
      }
      
      match /settings/booking {
        allow read: if true;
        allow write: if isOwner(userId);
      }
      
      match /settings/clinicHours {
        allow read: if true;
        allow write: if isOwner(userId);
      }
      
      match /settings/{document} {
        allow read: if isOwner(userId) || isClinicMember(userId);
        allow write: if isOwner(userId);
      }
      
      match /company_data/{docId} {
        allow read, write: if isOwner(userId);
      }
      
      match /simulations/{docId} {
        allow read, write: if isOwner(userId);
      }
      
      match /calculators/{docId} {
        allow read, write: if isOwner(userId);
      }
      
      match /financial_control/{docId} {
        allow read, write: if isOwner(userId);
      }
      
      match /sales_management/{docId} {
        allow read, write: if isOwner(userId);
      }
      
      match /medications/{medicationId} {
        allow read, write: if isAuthenticated() && isClinicMember(userId);
      }
      
      match /measurements/{measurementId} {
        allow read, write: if isAuthenticated() && isClinicMember(userId);
      }
      
      match /clinics/{clinicId} {
        allow read, write: if isAuthenticated() && isClinicMember(userId);
      }
      
      match /invoiceRequests/{docId} {
        allow read, write: if isAuthenticated() && isClinicMember(userId);
      }
      
      match /accountingDocuments/{docId} {
        allow read: if isAuthenticated() && isClinicMember(userId);
        allow write: if isMasterAdmin();
      }
      
      match /receipts/{docId} {
        allow read, write: if isAuthenticated() && isClinicMember(userId);
      }
    }

    // =============================================
    // HEALTH INSURANCE & TISS DATA
    // =============================================
    match /health_insurances/{docId} {
      allow read, write: if isAuthenticated();
    }
    
    match /tiss_tables/{docId} {
      allow read, write: if isAuthenticated();
    }
    
    match /tiss_guides/{docId} {
      allow read, write: if isAuthenticated();
    }
    
    match /tiss_batches/{docId} {
      allow read, write: if isAuthenticated();
    }
    
    match /tiss_glosas/{docId} {
      allow read, write: if isAuthenticated();
    }

    // =============================================
    // CONTRACTS & PROFESSIONALS (Semi-public for booking)
    // =============================================
    match /contracts/{contractId} {
      allow read: if true; // Public needs professional names for booking
      allow write: if isAuthenticated();
    }

    match /professionals/{profId} {
      allow read: if true; // Public
      allow write: if isAuthenticated();
    }

    // =============================================
    // FINANCIAL - REPASSE
    // =============================================
    match /repasse_statements/{statementId} {
      allow read, write: if isAuthenticated();
    }

    match /consultation_billing/{billingId} {
      allow read, write: if isAuthenticated();
    }

    // =============================================
    // CLINIC LINK REQUESTS
    // =============================================
    match /clinic_link_requests/{requestId} {
      allow read, write: if isAuthenticated();
    }

    // =============================================
    // LGPD / DATA CONSENT (Authenticated only)
    // =============================================
    match /lgpd_consents/{consentId} {
      allow read, write: if isAuthenticated();
    }

    // =============================================
    // CATCH-ALL: Deny everything else by default
    // =============================================
  }
}