# ============================================
# ERCMed - Environment Variables
# ============================================
# IMPORTANT: This file is NOT committed to Git.
# Copy this file to .env and fill in the actual values.
# For CI/CD (GitHub Actions, etc.), add these as Repository Secrets.
# ============================================

# ---- Firebase Config ----
# Found at: Firebase Console > Project Settings > General > Your apps
VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project_id.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# ---- Google Gemini API ----
# Found at: https://aistudio.google.com/app/apikey
VITE_GOOGLE_GENAI_API_KEY=your_gemini_api_key_here

# ---- Groq API (Clinical AI Summaries) ----
# Found at: https://console.groq.com/keys
VITE_GROQ_API_KEY=your_groq_api_key_here
VITE_GROQ_API_KEY_ALT=your_groq_api_key_alt_here
